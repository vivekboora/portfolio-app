# Copy this file to ".env" for local development and fill in real values.
# On Render, set these same keys in the dashboard under Environment instead
# of uploading a .env file.

SECRET_KEY=change-this-to-a-long-random-string

# --- Option A (recommended): full connection string from Aiven ---
# Aiven's "Service URI" looks like mysql://user:pass@host:port/defaultdb
# SQLAlchemy needs the pymysql driver named explicitly:
DATABASE_URL=mysql+pymysql://avnadmin:yourpassword@jovian-careers-website-v2-jovian-careers-website-project.h.aivencloud.com:12345/defaultdb

# --- Option B: individual pieces (used only if DATABASE_URL is not set) ---
DB_USER=avnadmin
DB_PASSWORD=yourpassword
DB_HOST=jovian-careers-website-v2-jovian-careers-website-project.h.aivencloud.com
DB_PORT=12345
DB_NAME=defaultdb

# Aiven requires SSL. Download the CA certificate from the Aiven console
# (Service Overview -> "CA Certificate" download button), save it as
# ca.pem in the project root, and leave this as true.
DB_USE_SSL=true
SSL_CA_PATH=ca.pem
